// ============================================
// Kopi Bima — Prisma Schema (PostgreSQL)
// ============================================

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

model Database {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  jalurs    Jalur[]
}

model Jalur {
  id         String   @id @default(uuid())
  name       String
  createdAt  DateTime @default(now())
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  alamats    Alamat[]
}

model Alamat {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  jalurId   String
  jalur     Jalur    @relation(fields: [jalurId], references: [id], onDelete: Cascade)
  outlets   Outlet[]
}

model Outlet {
  id        String   @id @default(uuid())
  noInduk   String
  outlet    String
  tglDaftar String
  alamatId  String
  alamat    Alamat   @relation(fields: [alamatId], references: [id], onDelete: Cascade)
  orders    Order[]
  payments  Payment[]
}

model Order {
  id           String   @id @default(uuid())
  order        Float
  harga        Float
  totalBayar   Float
  totalPiutang Float
  status       String
  orderStatus  String   @default("Sukses")
  tglOrder     String
  createdAt    DateTime @default(now())
  paymentMethod String   @default("Cash")
  outletId     String
  outlet       Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model CoffeeStock {
  id        String   @id @default(uuid())
  name      String
  sku       String   @unique
  quantity  Float
  unit      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String   @id @default(uuid())
  amount        Float
  paymentMethod String   @default("Cash")
  tglPayment    String
  createdAt     DateTime @default(now())
  outletId      String
  outlet        Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // SHA-256 hashed password
  role      String   @default("USER") // "ADMIN" | "USER"
  createdAt DateTime @default(now())
}

